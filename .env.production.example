# ============================================================================
# Production Environment Variables
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to git!
# ============================================================================

# ── Database ────────────────────────────────────────────────────────
# Railway/Render provides this automatically when you add PostgreSQL
POSTGRES_USER=zenon
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=zenon_croptrial
DATABASE_URL="postgresql://zenon:CHANGE_THIS_TO_A_STRONG_PASSWORD@localhost:5432/zenon_croptrial?schema=public"

# ── Authentication ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── Application ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── File Upload ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Razorpay Payment Gateway ───────────────────────────────────────
# Use LIVE keys (not test) for production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx

# ── Frontend API URL ────────────────────────────────────────────────
# For same-domain deploy (nginx reverse proxy): /api/v1
# For separate domain deploy: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=/api/v1
